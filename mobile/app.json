{
  "expo": {
    "name": "RasoiLink",
    "slug": "rasoilink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B00"
    },
    "scheme": "rasoilink",
    "plugins": ["expo-router", "expo-secure-store"],
    "ios": { "supportsTablet": true },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#FF6B00" } },
    "web": { "bundler": "metro" }
  }
}
