{
  "expo": {
    "name": "RasoiLink",
    "slug": "rasoilink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B00"
    },
    "scheme": "rasoilink",
    "plugins": [
      "expo-secure-store",
      "expo-router"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rasoilink.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.rasoilink.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#FF6B00",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "6c2e13bc-af65-43e0-b984-19dbdcea8ad1"
      }
    },
    "owner": "vipul9811karuna"
  }
}