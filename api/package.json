{
  "name": "rasoilink-api",
  "version": "1.0.0",
  "type": "module",
  "description": "RasoiLink Backend API",
  "scripts": {
    "dev":       "tsx watch src/index.ts",
    "build":     "tsc",
    "start":     "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify":          "^4.26.0",
    "@fastify/cors":    "^8.5.0",
    "@fastify/jwt":     "^8.0.0",
    "pg":               "^8.11.3",
    "dotenv":           "^16.4.5",
    "zod":              "^3.22.4",
    "bcrypt":           "^5.1.1",
    "pino":             "^8.19.0",
    "pino-pretty":      "^11.0.0"
  },
  "devDependencies": {
    "@types/node":      "^20.11.5",
    "@types/pg":        "^8.11.0",
    "@types/bcrypt":    "^5.0.2",
    "typescript":       "^5.3.3",
    "tsx":              "^4.7.0"
  }
